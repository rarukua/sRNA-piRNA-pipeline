// ============================================================
// nextflow.config — piRNA Pipeline v2.0 Configuration
// ============================================================
// Generalized for multi-dataset analysis across different
// library preps, adapter types, and sequencing platforms.
// ============================================================

params {
    // ── Input ──
    samplesheet     = "assets/samplesheet.csv"

    // ── Reference files ──
    genome_dir      = "/path/to/STAR_genome_index"
    bowtie2_index   = "/path/to/bowtie2_index/genome"
    bowtie1_index   = "/home/zgao/GEOdata/bowtie1_index/hg38"
    gtf             = "/home/zgao/piRNA_anno/unified_human_piRNA.gtf"

    // ── Aligner selection ──
    // 'bowtie1' recommended for piRNA quantification (ungapped, precise)
    // 'bowtie2' or 'star' available for verify/discovery tasks
    aligner         = "bowtie1"

    // ── Fastp: generalized trimming ──
    // No adapter sequence specified — fastp auto-detects all Illumina adapters
    // polyG/polyX trimming is always on (harmless no-op if artifacts absent)
    min_len         = 24       // piRNA minimum length
    max_len         = 42       // piRNA maximum length
    quality_phred   = 20       // base quality threshold
    poly_g_min_len  = 10       // minimum polyG length to trigger trimming
    poly_x_min_len  = 10       // minimum polyX length to trigger trimming

    // ── Bowtie1 parameters ──
    bowtie1_mismatch = 1       // -v mode: allow 1 mismatch across entire read
                               // Captures SNV-containing isoforms while staying specific
                               // Set to 0 for strict matching (your original pipeline)

    // ── STAR parameters (if using STAR aligner) ──
    star_mismatch   = 0
    star_multimap   = 1000000
    star_min_match  = 22

    // ── Bowtie2 parameters (if using Bowtie2 aligner) ──
    bowtie2_n_ceil  = 0

    // ── featureCounts parameters ──
    fc_feature_type  = "exon"   // GTF column 3 label for countable regions
                                // Our GTF uses "exon"; old piRBase GTF used "piRbase"
    fc_strandedness  = 1        // 1=forward strand (piRNAs are strand-specific)
                                // 0=unstranded, 2=reverse
    min_overlap      = 15       // minimum read-feature overlap (bp)
                                // 15nt balances specificity vs isoform capture
                                // with --fraction, overlapping isoforms get split counts

    // ── Pipeline mode ──
    mode            = "full"    // 'qc_only' or 'full'

    // ── Output ──
    outdir          = "results"
    multiqc_title   = "piRNA Pipeline QC Report"
}

// ── Execution profiles ──
profiles {

    standard {
        process.executor = 'local'
    }

    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        process.container      = 'zgao/pirna-pipeline:latest'
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        process.container      = 'docker://zgao/pirna-pipeline:latest'
    }

    // Slurm HPC profile
    slurm {
        process.executor = 'slurm'
        process.queue    = 'normal'
    }

    test {
        params.samplesheet   = "assets/samplesheet_test.csv"
        params.genome_dir    = "test_data/star_index"
        params.bowtie2_index = "test_data/bowtie2_index/genome"
        params.bowtie1_index = "test_data/bowtie1_index/genome"
        params.gtf           = "test_data/test_annotation.gtf"
        params.outdir        = "test_results"
    }
}

// ── Resource configuration ──
process {
    cpus   = 4
    memory = '8 GB'
    time   = '2h'

    withName: 'STAR_ALIGN' {
        cpus   = 16
        memory = '32 GB'
        time   = '4h'
    }

    withName: 'BOWTIE1_ALIGN' {
        cpus   = 8
        memory = '16 GB'
        time   = '4h'
    }

    withName: 'BOWTIE2_ALIGN' {
        cpus   = 8
        memory = '16 GB'
        time   = '4h'
    }

    withName: 'FEATURECOUNTS' {
        cpus   = 8
        memory = '8 GB'
    }

    withName: 'MERGE_COUNTS' {
        cpus   = 1
        memory = '16 GB'
    }
}

// ── Nextflow execution settings ──
executor {
    queueSize = 10
}

// ── Report generation ──
report {
    enabled = true
    file    = "${params.outdir}/pipeline_report.html"
}

timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_timeline.html"
}

dag {
    enabled = true
    file    = "${params.outdir}/pipeline_dag.html"
}
